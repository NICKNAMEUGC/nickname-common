# nickname-common — Variables de entorno
# Estas variables las usan los módulos de la librería compartida.
# Cada agente que use nickname-common debe tener estas vars en su propio .env.

# Logging
LOG_LEVEL=INFO

# Odoo XML-RPC (usado por odoo_client.OdooService)
ODOO_URL=https://tu-empresa.odoo.com
ODOO_DB=tu_base_datos
ODOO_USERNAME=admin@tu-empresa.com
ODOO_API_KEY=tu_api_key_aqui
ODOO_COMPANY_ID=2
ODOO_XMLRPC_TIMEOUT=20
ODOO_CIRCUIT_BREAKER_TIMEOUT=60

# HubSpot REST (usado por hubspot_client.BaseHubSpotService)
HUBSPOT_ACCESS_TOKEN=pat-xxxx-xxxx-xxxx
